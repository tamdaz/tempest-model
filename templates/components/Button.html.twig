<button
    type="{{ type ?? 'button' }}"
    class="inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 disabled:pointer-events-none disabled:opacity-50
        {% if (variant ?? 'primary') == 'primary' %}bg-gray-900 text-white hover:bg-gray-700
        {% elseif variant == 'secondary' %}border border-gray-300 bg-white text-gray-900 hover:bg-gray-50
        {% elseif variant == 'danger' %}bg-red-600 text-white hover:bg-red-500
        {% endif %} {{ class ?? '' }}"
    {% if disabled ?? false %}disabled{% endif %}
>
    {{ label ?? '' }}{% block content %}{% endblock %}
</button>
