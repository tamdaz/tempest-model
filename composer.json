{
    "name": "tempest/app",
    "type": "project",
    "require": {
        "tempest/framework": "^3.0",
        "twig/twig": "^3.23",
        "tempest/view": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.8",
        "phpstan/phpstan": "^2.1",
        "symfony/var-dumper": "^7.4",
        "carthage-software/mago": "^1.14.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Config\\": "config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php ./vendor/bin/tempest install framework -f",
            "@php ./tempest discovery:generate --no-interaction",
            "@php ./tempest key:generate"
        ],
        "post-autoload-dump": [
            "@php ./vendor/bin/tempest discovery:generate --no-interaction"
        ],
        "phpunit": "vendor/bin/phpunit --display-warnings --display-skipped --display-deprecations --display-errors --display-notices",
        "lint": "vendor/bin/phpstan"
    },
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
